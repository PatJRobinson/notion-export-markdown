def load_migration_state(client: NotionClient, args: argparse.Namespace) -> MigrationState:
    names = {
        "research_questions": args.research_questions_db,
        "contributions": args.contributions_db,
        "core_claims": args.core_claims_db,
        "risks": args.risks_db,
    }
    data_sources: Dict[str, Dict[str, Any]] = {}
    schemas: Dict[str, Dict[str, Any]] = {}
    rows: Dict[str, List[Dict[str, Any]]] = {}
    indexes: Dict[str, Dict[str, Dict[str, Any]]] = {}

    for key, name in names.items():
        ds = discover_data_source(client, name)
        data_sources[key] = ds
        schemas[key] = data_source_properties(ds)
        progress(f"{key}: {ds.get('title_text', name)} ({ds['id']})")
        rows[key] = client.query_data_source_all(ds["id"])
        indexes[key] = build_title_index(rows[key])

    return MigrationState(data_sources=data_sources, schemas=schemas, rows=rows, indexes=indexes)


def migration_aliases_for(title: str) -> List[str]:
    aliases: List[str] = []
    for item in RQS:
        if normalize_title(item["title"]) == normalize_title(title):
            aliases.extend(item.get("aliases", []))
    for item in CONTRIBUTIONS:
        if normalize_title(item["title"]) == normalize_title(title):
            aliases.extend(item.get("aliases", []))
    return aliases


def resolve_ids(index: Dict[str, Dict[str, Any]], titles: Sequence[str], warnings: List[str], context: str) -> List[str]:
    ids: List[str] = []
    for title in titles:
        page = find_indexed(index, title, migration_aliases_for(title))
        if page:
            ids.append(page["id"])
        else:
            warnings.append(f"{context}: could not resolve relation target '{title}'")
    return ids


def add_property_if_changed(
    page: Optional[Dict[str, Any]],
    schema: Dict[str, Any],
    properties: Dict[str, Any],
    candidates: Sequence[str],
    payload: Dict[str, Any],
    missing: List[str],
    context: str,
    client: Optional[NotionClient] = None,
) -> None:
    prop_name = actual_property_name(schema, candidates)
    if not prop_name:
        missing.append(f"{context}: missing property {'/'.join(candidates)}")
        return
    if page is None:
        properties[prop_name] = payload
        return
    ptype = property_type(schema, prop_name)
    if ptype == "relation":
        wanted = {rel["id"] for rel in payload.get("relation", [])}
        if current_relation_ids(page, prop_name) != wanted:
            properties[prop_name] = payload
        return
    current = current_simple_value(page, prop_name)
    if ptype in {"title", "rich_text", "select", "status", "multi_select"}:
        wanted = ""
        if "title" in payload:
            wanted = notion_rich_text_to_text(payload["title"])
        elif "rich_text" in payload:
            wanted = notion_rich_text_to_text(payload["rich_text"])
        elif "select" in payload:
            wanted = payload["select"]["name"]
        elif "status" in payload:
            wanted = payload["status"]["name"]
        elif "multi_select" in payload:
            wanted = ", ".join(x["name"] for x in payload["multi_select"])
        if client and ptype in {"title", "rich_text"} and current.strip() != wanted.strip():
            current = current_full_text_value(client, page, prop_name)
        if current.strip() != wanted.strip():
            properties[prop_name] = payload
        return
    properties[prop_name] = payload


def plan_note_if_missing(
    client: NotionClient,
    page: Optional[Dict[str, Any]],
    database: str,
    title: str,
    note_title: str,
    note_body: str,
    warnings: List[str],
) -> Optional[Action]:
    if page is None:
        return None
    try:
        blocks = client.retrieve_block_children_all(page["id"])
    except Exception as exc:
        warnings.append(f"{database}::{title}: could not inspect page body for migration note: {exc}")
        return None
    marker_text = f"{MIGRATION_MARKER} {note_title}"
    if any(marker_text in block_plain_text(block) for block in blocks):
        return None
    return Action(
        kind="append-note",
        database=database,
        title=title,
        page_id=page["id"],
        note_title=note_title,
        note_body=note_body,
    )


def plan_rq_actions(client: NotionClient, state: MigrationState, warnings: List[str], missing: List[str]) -> List[Action]:
    actions: List[Action] = []
    schema = state.schemas["research_questions"]
    index = state.indexes["research_questions"]
    title_prop = title_property_name(schema)
    status_prop = actual_property_name(schema, ["Status"])

    for rq in RQS:
        page = find_indexed(index, rq["title"], rq["aliases"])
        properties: Dict[str, Any] = {}
        if page is None:
            add_property_if_changed(None, schema, properties, [title_prop], title_payload(rq["title"]), missing, rq["title"])
        add_property_if_changed(page, schema, properties, ["question", "Question", "Description"], rich_text_payload(rq["question"]), missing, rq["title"], client=client)
        if status_prop and property_type(schema, status_prop) in {"select", "status", "multi_select"}:
            add_property_if_changed(page, schema, properties, [status_prop], selectish_payload(property_type(schema, status_prop) or "", "Active"), missing, rq["title"])

        if page is None:
            actions.append(Action(
                kind="create-page",
                database="research_questions",
                title=rq["title"],
                properties=properties,
                create_children=note_children("RQ migration note", rq["note"]),
            ))
        elif properties:
            actions.append(Action(kind="update-page", database="research_questions", title=page_title_from_properties(page.get("properties", {})), page_id=page["id"], properties=properties))
        note_action = plan_note_if_missing(client, page, "research_questions", rq["title"], "RQ migration note", rq["note"], warnings)
        if note_action:
            actions.append(note_action)

    for old_title, (status, superseded_by, note) in OLD_RQS.items():
        page = find_indexed(index, old_title)
        if not page:
            warnings.append(f"Old RQ not found in active research question database: {old_title}")
            continue
        properties = {}
        status_prop = actual_property_name(schema, ["Status"])
        if status_prop and property_type(schema, status_prop) in {"select", "status", "multi_select"}:
            add_property_if_changed(page, schema, properties, [status_prop], selectish_payload(property_type(schema, status_prop) or "", status), missing, old_title)
        rel_prop = actual_property_name(schema, ["Superseded by", "Superseded By", "Replacement RQs", "Research Questions"])
        if rel_prop and property_type(schema, rel_prop) == "relation":
            ids = resolve_ids(index, superseded_by, warnings, old_title)
            add_property_if_changed(page, schema, properties, [rel_prop], relation_payload(ids), missing, old_title)
        else:
            missing.append(f"{old_title}: missing relation-like superseded-by property")
        if properties:
            actions.append(Action(kind="update-page", database="research_questions", title=old_title, page_id=page["id"], properties=properties))
        note_action = plan_note_if_missing(client, page, "research_questions", old_title, "Historical RQ migration note", note, warnings)
        if note_action:
            actions.append(note_action)

    return actions


def plan_contribution_actions(client: NotionClient, state: MigrationState, warnings: List[str], missing: List[str]) -> List[Action]:
    actions: List[Action] = []
    schema = state.schemas["contributions"]
    index = state.indexes["contributions"]
    rq_index = state.indexes["research_questions"]
    title_prop = title_property_name(schema)

    for contribution in CONTRIBUTIONS:
        page = find_indexed(index, contribution["title"], contribution["aliases"])
        properties: Dict[str, Any] = {}
        if page is None or page_title_from_properties(page.get("properties", {})) != contribution["title"]:
            add_property_if_changed(page, schema, properties, [title_prop], title_payload(contribution["title"]), missing, contribution["title"], client=client)
        add_property_if_changed(page, schema, properties, ["Statement", "Claim", "Description"], rich_text_payload(contribution["claim"]), missing, contribution["title"], client=client)
        add_property_if_changed(page, schema, properties, ["Role"], rich_text_payload(contribution["role"]), missing, contribution["title"], client=client)

        status_prop = actual_property_name(schema, ["Status"])
        if status_prop and property_type(schema, status_prop) in {"select", "status", "multi_select"}:
            add_property_if_changed(page, schema, properties, [status_prop], selectish_payload(property_type(schema, status_prop) or "", contribution["status"]), missing, contribution["title"])
        else:
            missing.append(f"{contribution['title']}: missing Status property")

        rq_prop = actual_property_name(schema, ["Research Questions", "RQs", "Primary RQ"])
        rq_ids = resolve_ids(rq_index, [contribution["primary"], *contribution["secondary"]], warnings, contribution["title"])
        if rq_prop and property_type(schema, rq_prop) == "relation":
            add_property_if_changed(page, schema, properties, [rq_prop], relation_payload(rq_ids), missing, contribution["title"])
        else:
            missing.append(f"{contribution['title']}: missing Research Questions relation property")

        if page is None:
            actions.append(Action(
                kind="create-page",
                database="contributions",
                title=contribution["title"],
                properties=properties,
                create_children=note_children("Contribution migration note", contribution["note"]),
            ))
        elif properties:
            rels = len(properties.get(rq_prop, {}).get("relation", [])) if rq_prop else 0
            actions.append(Action(kind="update-page", database="contributions", title=page_title_from_properties(page.get("properties", {})), page_id=page["id"], properties=properties, relation_count=rels))
        note_action = plan_note_if_missing(client, page, "contributions", contribution["title"], "Contribution migration note", contribution["note"], warnings)
        if note_action:
            actions.append(note_action)

    for old_title, (status, absorbed_into, note) in OLD_CONTRIBUTIONS.items():
        page = find_indexed(index, old_title)
        if not page:
            warnings.append(f"Old contribution not found in active contributions database: {old_title}")
            continue
        properties = {}
        status_prop = actual_property_name(schema, ["Status"])
        if status_prop and property_type(schema, status_prop) in {"select", "status", "multi_select"}:
            add_property_if_changed(page, schema, properties, [status_prop], selectish_payload(property_type(schema, status_prop) or "", status), missing, old_title)
        rel_prop = actual_property_name(schema, ["Absorbed into", "Absorbed Into", "Replacement Contributions", "Contributions"])
        if rel_prop and property_type(schema, rel_prop) == "relation":
            ids = resolve_ids(index, absorbed_into, warnings, old_title)
            add_property_if_changed(page, schema, properties, [rel_prop], relation_payload(ids), missing, old_title)
        else:
            missing.append(f"{old_title}: missing relation-like absorbed-into property")
        if properties:
            actions.append(Action(kind="update-page", database="contributions", title=old_title, page_id=page["id"], properties=properties))
        note_action = plan_note_if_missing(client, page, "contributions", old_title, "Historical contribution migration note", note, warnings)
        if note_action:
            actions.append(note_action)

    return actions


def plan_core_claim_actions(state: MigrationState, warnings: List[str], missing: List[str]) -> List[Action]:
    actions: List[Action] = []
    schema = state.schemas["core_claims"]
    claim_index = state.indexes["core_claims"]
    rq_index = state.indexes["research_questions"]
    contribution_index = state.indexes["contributions"]
    rq_prop = actual_property_name(schema, ["Research Questions", "RQs"])
    contribution_prop = actual_property_name(schema, ["Contributions", "Contribution"])

    desired_contribs_by_claim: Dict[str, Set[str]] = {}
    desired_rqs_by_claim: Dict[str, Set[str]] = {}
    for rq_title, (contribution_title, claim_titles) in CLAIM_LINKS.items():
        for claim_title in claim_titles:
            desired_contribs_by_claim.setdefault(claim_title, set()).add(contribution_title)
            desired_rqs_by_claim.setdefault(claim_title, set()).add(rq_title)

    for claim_title in sorted(set(desired_contribs_by_claim) | set(desired_rqs_by_claim)):
        page = find_indexed(claim_index, claim_title)
        if not page:
            warnings.append(f"Core claim not found: {claim_title}")
            continue
        properties: Dict[str, Any] = {}
        if contribution_prop and property_type(schema, contribution_prop) == "relation":
            ids = resolve_ids(contribution_index, sorted(desired_contribs_by_claim.get(claim_title, set())), warnings, claim_title)
            add_property_if_changed(page, schema, properties, [contribution_prop], relation_payload(ids), missing, claim_title)
        else:
            missing.append(f"{claim_title}: missing Contributions relation property")
        if rq_prop and property_type(schema, rq_prop) == "relation":
            ids = resolve_ids(rq_index, sorted(desired_rqs_by_claim.get(claim_title, set())), warnings, claim_title)
            add_property_if_changed(page, schema, properties, [rq_prop], relation_payload(ids), missing, claim_title)
        else:
            missing.append(f"{claim_title}: missing Research Questions relation property")
        if properties:
            rels = sum(len(v.get("relation", [])) for v in properties.values())
            actions.append(Action(kind="update-page", database="core_claims", title=claim_title, page_id=page["id"], properties=properties, relation_count=rels))
    return actions


def plan_risk_actions(client: NotionClient, state: MigrationState, warnings: List[str], missing: List[str]) -> List[Action]:
    actions: List[Action] = []
    schema = state.schemas["risks"]
    risk_index = state.indexes["risks"]
