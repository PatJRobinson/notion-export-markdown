def action_description(action: Action) -> str:
    if action.kind == "create-page":
        return f"create {action.database}: {action.title}"
    if action.kind == "update-page":
        return f"update {action.database}: {action.title} ({', '.join(action.properties.keys())})"
    if action.kind == "append-note":
        return f"append note to {action.database}: {action.title} :: {action.note_title}"
    if action.kind == "warning":
        return f"warning: {action.warning}"
    return f"{action.kind}: {action.database}: {action.title}"


def apply_actions(client: NotionClient, state: MigrationState, actions: List[Action], dry_run: bool) -> Summary:
    summary = Summary()
    ds_by_key = state.data_sources
    for action in actions:
        progress(action_description(action))
        if dry_run:
            continue
        if action.kind == "create-page":
            ds = ds_by_key.get(action.database)
            if not ds:
                # Thesis note may target a dynamically discovered database by display name.
                ds = discover_data_source(client, action.database)
            client.create_page(ds["id"], action.properties, children=action.create_children)
            summary.created += 1
            if action.create_children:
                summary.notes_added += 1
        elif action.kind == "update-page":
            if not action.page_id:
                summary.warnings.append(f"Cannot update without page id: {action.title}")
                continue
            client.update_page(action.page_id, action.properties)
            summary.updated += 1
            summary.relations_added += action.relation_count
        elif action.kind == "append-note":
            if not action.page_id or not action.note_title or not action.note_body:
                summary.warnings.append(f"Cannot append note without complete note data: {action.title}")
                continue
            client.append_block_children(action.page_id, note_children(action.note_title, action.note_body))
            summary.notes_added += 1
    return summary


def print_plan(actions: List[Action], summary: Summary, dry_run: bool) -> None:
    print("Planned actions:" if dry_run else "Applied actions:")
    if not actions:
        print("- no page mutations needed")
    for action in actions:
        print(f"- {action_description(action)}")
    print("")
    print("Summary:")
    print(f"- pages created: {'planned ' if dry_run else ''}{sum(1 for a in actions if a.kind == 'create-page')}")
    print(f"- pages updated: {'planned ' if dry_run else ''}{sum(1 for a in actions if a.kind == 'update-page')}")
    print(f"- relations touched: {'planned ' if dry_run else ''}{sum(a.relation_count for a in actions)}")
    print(f"- notes added: {'planned ' if dry_run else ''}{sum(1 for a in actions if a.kind == 'append-note') + sum(1 for a in actions if a.kind == 'create-page' and a.create_children)}")
    print(f"- properties missing/skipped: {len(summary.missing)}")
    print(f"- warnings/manual follow-ups: {len(summary.warnings)}")
    if summary.missing:
        print("")
        print("Missing/skipped properties:")
        for item in summary.missing:
            print(f"- {item}")
    if summary.warnings:
        print("")
        print("Warnings/manual follow-ups:")
        for item in summary.warnings:
            print(f"- {item}")


