def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser()
    parser.add_argument("--research-questions-db", default=DEFAULT_DATABASES["research_questions"], help="Research Questions data source title/id")
    parser.add_argument("--contributions-db", default=DEFAULT_DATABASES["contributions"], help="Contributions data source title/id")
    parser.add_argument("--core-claims-db", default=DEFAULT_DATABASES["core_claims"], help="Core Claims data source title/id")
    parser.add_argument("--risks-db", default=DEFAULT_DATABASES["risks"], help="Risks data source title/id")
    sub = parser.add_subparsers(dest="command", required=True)

    sub.add_parser("plan-rq-migration", help="Report intended June 2026 RQ migration changes without writing")
    sub.add_parser("apply-rq-migration", help="Apply the June 2026 RQ migration")

    export_schema = sub.add_parser("export-schema", help="Print selected data source schemas as JSON")
    export_schema.add_argument("databases", nargs="*", default=list(DEFAULT_DATABASES.values()), help="Data source titles/ids")

    sub.add_parser("list-databases", help="List visible Notion data sources")

    list_pages = sub.add_parser("list-pages", help="List pages in a data source")
    list_pages.add_argument("--database", required=True, help="Data source title/id")

    find_page = sub.add_parser("find-page", help="Search visible pages by title")
    find_page.add_argument("--title", required=True, help="Title text to search for")

    return parser


def main() -> None:
    parser = build_parser()
    args = parser.parse_args()
    token = os.environ.get("NOTION_TOKEN")
    if not token:
        die("Missing NOTION_TOKEN environment variable.")
    client = NotionClient(token)

    try:
        if args.command == "list-databases":
            cmd_list_databases(client, args)
            return
        if args.command == "export-schema":
            cmd_export_schema(client, args)
            return
        if args.command == "list-pages":
            cmd_list_pages(client, args)
            return
        if args.command == "find-page":
            cmd_find_page(client, args)
            return
        if args.command in {"plan-rq-migration", "apply-rq-migration"}:
            dry_run = args.command == "plan-rq-migration"
            _, actions, summary = plan_migration(client, args)
            apply_summary = apply_actions(client, _, actions, dry_run=dry_run)
            summary.created = apply_summary.created
            summary.updated = apply_summary.updated
            summary.relations_added = apply_summary.relations_added
            summary.notes_added = apply_summary.notes_added
            summary.warnings.extend(apply_summary.warnings)
            print_plan(actions, summary, dry_run=dry_run)
            return
    except Exception as exc:
        die(str(exc))


if __name__ == "__main__":
    main()
