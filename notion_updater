        ds = discover_data_source(client, name)
        props = data_source_properties(ds)
        out[ds.get("title_text", name)] = {
            "id": ds["id"],
            "properties": {
                prop_name: {"id": spec.get("id"), "type": spec.get("type")}
                for prop_name, spec in props.items()
            },
        }
    print(json.dumps(out, indent=2, sort_keys=True))


def cmd_list_pages(client: NotionClient, args: argparse.Namespace) -> None:
    ds = discover_data_source(client, args.database)
    rows = client.query_data_source_all(ds["id"])
    for row in sorted(rows, key=lambda r: normalize_title(page_title_from_properties(r.get("properties", {})))):
        print(f"{page_title_from_properties(row.get('properties', {}))}\t{row['id']}")


def cmd_find_page(client: NotionClient, args: argparse.Namespace) -> None:
    results = client.search(query=args.title, object_value="page")
    matched = [
        result for result in results
        if normalize_title(args.title) in normalize_title(page_title_from_properties(result.get("properties", {})))
        or normalize_title(args.title) in normalize_title(safe_text(result.get("title")) or safe_text(result.get("name")))
    ]
    for page in matched or results:
        title = page_title_from_properties(page.get("properties", {})) or safe_text(page.get("title")) or safe_text(page.get("name")) or "Untitled"
        print(f"{title}\t{page.get('id')}\t{page.get('url', '')}")


