def plan_thesis_note_actions(client: NotionClient, state: MigrationState, warnings: List[str]) -> List[Action]:
    actions: List[Action] = []
    note_ds: Optional[Dict[str, Any]] = None
    for name in ["notes", "planning", "research plan", "research-plan"]:
        try:
            candidate = discover_data_source(client, name)
            candidate_title = safe_text(candidate.get("title_text"))
            normalized = normalize_title(candidate_title)
            if normalized in {normalize_title(name), "notes", "planning", "research plan", "research-plan"}:
                note_ds = candidate
                break
            if any(word in normalized for word in ["note", "planning"]) and "research question" not in normalized:
                note_ds = candidate
                break
        except Exception:
            continue
    if note_ds:
        schema = data_source_properties(note_ds)
        rows = client.query_data_source_all(note_ds["id"])
        index = build_title_index(rows)
        page = find_indexed(index, THESIS_NOTE_TITLE)
        title_prop = title_property_name(schema)
        if not page:
            actions.append(Action(
                kind="create-page",
                database=note_ds.get("title_text", "notes"),
                title=THESIS_NOTE_TITLE,
                properties={title_prop: title_payload(THESIS_NOTE_TITLE)},
                create_children=note_children("Thesis-level migration note", THESIS_NOTE_BODY),
            ))
        else:
            note_action = plan_note_if_missing(client, page, note_ds.get("title_text", "notes"), THESIS_NOTE_TITLE, "Thesis-level migration note", THESIS_NOTE_BODY, warnings)
            if note_action:
                actions.append(note_action)
        return actions

    warnings.append("No Notes/Planning/Research-plan database found; adding thesis-level note to active RQ pages.")
    for rq in RQS:
        page = find_indexed(state.indexes["research_questions"], rq["title"], rq["aliases"])
        note_action = plan_note_if_missing(client, page, "research_questions", rq["title"], THESIS_NOTE_TITLE, THESIS_NOTE_BODY, warnings)
        if note_action:
            actions.append(note_action)
    return actions


def plan_migration(client: NotionClient, args: argparse.Namespace) -> Tuple[MigrationState, List[Action], Summary]:
    warnings: List[str] = []
    missing: List[str] = []
    state = load_migration_state(client, args)
    actions: List[Action] = []
    actions.extend(plan_rq_actions(client, state, warnings, missing))
    actions.extend(plan_contribution_actions(client, state, warnings, missing))
    actions.extend(plan_core_claim_actions(state, warnings, missing))
    actions.extend(plan_risk_actions(client, state, warnings, missing))
    actions.extend(plan_thesis_note_actions(client, state, warnings))
    summary = Summary(warnings=warnings, missing=sorted(set(missing)))
    return state, actions, summary


