        for risk_title in risk_titles:
            desired_rqs_by_risk.setdefault(risk_title, set()).add(rq_title)

    for risk_title, rq_titles in sorted(desired_rqs_by_risk.items()):
        page = find_indexed(risk_index, risk_title)
        if not page:
            warnings.append(f"Risk not found: {risk_title}")
            continue
